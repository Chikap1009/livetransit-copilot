# .env.prod.example — production environment template for the droplet deploy (Phase J).
#
# Copy this to `.env` ON THE DROPLET (never commit the filled-in file) and replace every
# <PLACEHOLDER>. Docker Compose reads `.env` automatically. Secrets live ONLY here on the
# server, never in git (same Part 0 rule as local).

# --- Postgres (runs as a container on the droplet; data persists in the pgdata volume) ---
POSTGRES_USER=livetransit
POSTGRES_PASSWORD=<STRONG_RANDOM_PASSWORD>
POSTGRES_DB=livetransit
# DATABASE_URL is assembled by compose from the three vars above (host = service name
# "postgres"). Workers/API reach it on the internal compose network.

# --- Ingestion ---
MBTA_VEHICLE_POSITIONS_URL=https://cdn.mbta.com/realtime/VehiclePositions.pb
POLL_INTERVAL_SECONDS=10          # droplet has no storage/command limits; full fidelity

# --- Agent: LLM provider keys (fallback chain Gemini x5 -> Groq) ---
GEMINI_API_KEY=<GEMINI_KEY_1>
GEMINI_API_KEY_2=<GEMINI_KEY_2>
GEMINI_API_KEY_3=<GEMINI_KEY_3>
GEMINI_API_KEY_4=<GEMINI_KEY_4>
GEMINI_API_KEY_5=<GEMINI_KEY_5>
GROQ_API_KEY=<GROQ_KEY>

# --- Agent: rate limiting + CORS (public-facing hardening) ---
AGENT_RATE_LIMIT_PER_MIN=20
# EXACT Cloudflare Pages origin(s), comma-separated. No trailing slash. NOT "*" in prod.
CORS_ALLOW_ORIGINS=https://<your-project>.pages.dev

# --- Network Watchdog (background multi-agent monitor; uses LLM quota) ---
WATCHDOG_ENABLED=true
WATCHDOG_INTERVAL_SECONDS=900

# --- Tracing (Langfuse; agent observability). Leave blank to disable. ---
LANGFUSE_SECRET_KEY=<LANGFUSE_SECRET>
LANGFUSE_PUBLIC_KEY=<LANGFUSE_PUBLIC>
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Metrics dashboard ---
GF_SECURITY_ADMIN_PASSWORD=<STRONG_GRAFANA_PASSWORD>

# --- HTTPS option 1: Caddy + a DNS name pointing at the host (e.g. DuckDNS) ---
# Used by docker-compose.caddy.yml. Requires ports 80/443 open. Auto Let's Encrypt cert.
LT_DOMAIN=livetransit.duckdns.org

# --- HTTPS option 2: Cloudflare Tunnel (no open ports, needs a Cloudflare-managed domain) ---
# Used by docker-compose.prod.yml. Token from Cloudflare Zero Trust -> Networks -> Tunnels.
CLOUDFLARE_TUNNEL_TOKEN=<CLOUDFLARE_TUNNEL_TOKEN>

# --- Managed-Postgres alternative (Neon): OFF for the droplet deploy. Only set these if
#     you move the DB to a managed Apache-licensed Postgres that lacks TSL jobs. ---
DB_MAINTENANCE_ENABLED=false
DB_MAINTENANCE_INTERVAL_SECONDS=600
DB_RETENTION_INTERVAL=90 minutes
