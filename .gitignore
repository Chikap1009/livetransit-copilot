# ---------------------------------------------------------------------------
# LiveTransit Copilot — .gitignore
# Rule #7: secrets and large/regenerable files must NEVER enter git history.
# ---------------------------------------------------------------------------

# --- Secrets (THE critical ones — never commit) ---
# NOTE: gitignore comments must be on their OWN line — an inline '#' becomes part
# of the pattern and silently breaks the rule.
.env
.env.*
# ...but DO track the example templates (no real values):
!.env.example
!.env.prod.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/

# --- GTFS / real-time data dumps (large, regenerable) ---
# (comments on their own lines — an inline '#' becomes part of the pattern)
*.pb
*.zip
*.parquet
data/

# --- ML model artifacts (large binaries -> belong in R2, not git) ---
*.lgb
*.bin
models/

# --- Frontend (Next.js) build artifacts ---
node_modules/
.next/
out/
dist/

# --- Editor / OS noise ---
.DS_Store
Thumbs.db
.idea/
*.log

# --- Eval harness checkpoint (regenerable) ---
backend/app/evals/_progress.json
