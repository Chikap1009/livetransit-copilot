# LiveTransit Copilot — environment variable TEMPLATE (safe to commit; NO real secrets).
# Copy this file to .env and fill in real values:  cp .env.example .env

# --- Postgres (used by docker-compose to initialize the DB) ---
POSTGRES_USER=livetransit
POSTGRES_PASSWORD=change_me
POSTGRES_DB=livetransit

# --- Connection strings (used by our code later) ---
DATABASE_URL=postgresql://livetransit:change_me@localhost:5432/livetransit
REDIS_URL=redis://localhost:6379/0

# --- MBTA GTFS-Realtime feed ---
MBTA_VEHICLE_POSITIONS_URL=https://cdn.mbta.com/realtime/VehiclePositions.pb
POLL_INTERVAL_SECONDS=10

# --- LLM providers (agent brain) ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
