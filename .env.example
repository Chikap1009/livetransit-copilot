# LiveTransit Copilot — environment variable TEMPLATE (safe to commit; NO real secrets).
# Copy this file to .env and fill in real values:  cp .env.example .env

# --- Postgres (used by docker-compose to initialize the DB) ---
POSTGRES_USER=livetransit
POSTGRES_PASSWORD=change_me
POSTGRES_DB=livetransit

# --- Connection strings (used by our code later) ---
DATABASE_URL=postgresql://livetransit:change_me@localhost:5432/livetransit
REDIS_URL=redis://localhost:6379/0

# --- MBTA GTFS-Realtime feed ---
MBTA_VEHICLE_POSITIONS_URL=https://cdn.mbta.com/realtime/VehiclePositions.pb
POLL_INTERVAL_SECONDS=10

# --- LLM providers (agent brain) ---
# GEMINI_API_KEY is the priority key. Optionally add more Gemini keys from other
# Google projects/accounts (each has its own free quota) as backup tiers:
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY_2=second_gemini_key_optional
# GEMINI_API_KEY_3=third_gemini_key_optional
GROQ_API_KEY=your_groq_api_key_here

# --- Langfuse (agent tracing; optional — tracing is a no-op without these) ---
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
